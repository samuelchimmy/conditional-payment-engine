# ─────────────────────────────────────────────────────────────
# Tether Arena — AI Agent & Oracle  ·  environment template
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# ── Celo (chain) ──────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org
IOU_REGISTRY_V3=0x4708f9697c72bBBCa2ad82bbf03F2A8E0d62038C
# Executor wallet — must be an AUTHORIZED executor on the contract. Creates escrows.
EXECUTOR_PRIVATE_KEY=
# Vault wallet — must be the contract's vault. Resolves conditions + settles claims.
VAULT_PRIVATE_KEY=

# ── AI ────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=
# service_role key (the code reads SUPABASE_SERVICE_KEY, not ..._ROLE_KEY)
SUPABASE_SERVICE_KEY=

# ── X / Twitter ───────────────────────────────────────────────
# Bearer token (app-only) — REQUIRED to boot; used for the filtered stream + user lookups.
X_BEARER_TOKEN=
# App (consumer) keys.
X_API_KEY=
X_API_SECRET=
# Reply posting — use EITHER OAuth 2.0 (recommended, auto-refresh) OR OAuth 1.0a:
#  OAuth 2.0 user context (run scripts/x-oauth2-login.js to generate these):
X_OAUTH2_CLIENT_ID=
X_OAUTH2_CLIENT_SECRET=
X_OAUTH2_ACCESS_TOKEN=
X_OAUTH2_REFRESH_TOKEN=
#  OR OAuth 1.0a user tokens (leave OAuth 2.0 blank if using these):
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# The bot's own numeric user id — prevents it replying to its own tweets (recommended).
X_BOT_USER_ID=

# ── Discord ───────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Optional: set for webhook mode in production; omit for long-polling.
TELEGRAM_WEBHOOK_URL=

# ── Sports data (oracle sources) ──────────────────────────────
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_API_KEY=

# ── App ───────────────────────────────────────────────────────
WEBAPP_URL=https://tarena.xyz
